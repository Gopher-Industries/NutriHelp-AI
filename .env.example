# Core app settings
PORT=8000
NODE_ENV=development

# Active AI backend: Groq + Chroma
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Chroma configuration
# Use "cloud" for Chroma Cloud or "local" for a local PersistentClient store.
CHROMA_MODE=cloud
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_PATH=./.chroma
RAG_COLLECTION=aus_food_nutrition

# Optional legacy override
# Leave unset for the active runtime.
# NUTRIBOT_BACKEND=hf_legacy

# Other application env vars used elsewhere in the repo
JWT_TOKEN=
SUPABASE_URL=
SUPABASE_ANON_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
HF_SPACE_URL=
HF_SPACE_KEY=
